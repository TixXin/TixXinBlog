{
  "name": "server-main",
  "version": "0.0.1",
  "private": true,
  "description": "TixXinBlog 后端服务：NestJS + MikroORM + PostgreSQL，详见 docs/backend/",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "lint": "eslint src mikro-orm.config.ts",
    "lint:fix": "eslint src mikro-orm.config.ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "mikro-orm": "mikro-orm",
    "migration:create": "tsx scripts/migrate.ts create",
    "migration:up": "tsx scripts/migrate.ts up",
    "migration:list": "tsx scripts/migrate.ts list",
    "migration:check": "tsx scripts/migrate.ts check",
    "seed:dev": "tsx src/seeders/run-dev.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ]
  },
  "dependencies": {
    "@mikro-orm/core": "^6",
    "@mikro-orm/migrations": "^6",
    "@mikro-orm/nestjs": "^6.1.2",
    "@mikro-orm/postgresql": "^6",
    "@mikro-orm/seeder": "^6",
    "@nestjs/common": "^11",
    "@nestjs/config": "^4",
    "@nestjs/core": "^11",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11",
    "argon2": "^0.45.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "nestjs-pino": "^4.6.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@mikro-orm/cli": "^6",
    "@nestjs/cli": "^11",
    "@nestjs/schematics": "^11",
    "@nestjs/testing": "^11",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.4.2",
    "pino-pretty": "^13.1.3",
    "ts-jest": "^29.4.11",
    "tsx": "^4.23.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.64.0"
  }
}
